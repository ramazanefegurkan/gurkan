# =============================================================================
# Production Environment Variables
# Copy this file to .env and fill in real values before deploying.
# NEVER commit .env — it contains secrets.
# =============================================================================

# Domain (without https:// prefix)
DOMAIN=gurkan.example.com

# Caddy site address — set to the domain name for production (enables auto-HTTPS).
# Defaults to :80 (plain HTTP) when unset, suitable for local testing.
SITE_ADDRESS=gurkan.example.com

# PostgreSQL
POSTGRES_DB=gurkan
POSTGRES_USER=postgres
DB_PASSWORD=CHANGE_ME_strong_password_here

# JWT signing secret (minimum 32 characters)
JWT_SECRET=CHANGE_ME_at_least_32_characters_long_random_string

# API URL for frontend build (must match domain with /api suffix)
# Used at BUILD TIME — baked into the frontend JS bundle.
VITE_API_URL=https://gurkan.example.com/api
